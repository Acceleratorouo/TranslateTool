<Window x:Class="TranslateTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TranslateTool.Views"
        Title="翻译工具设置"
        MinHeight="480"
        MinWidth="440"
        Height="560"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource ClaudeBg}">

    <Window.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ClaudeSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ClaudeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ClaudeText}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ClaudeTextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource ClaudeTextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="{DynamicResource ClaudeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ClaudeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ClaudeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ClaudePrimary}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    AutomationProperties.Name="设置标题">
            <TextBlock Text="API 配置"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource ClaudeText}"/>
            <TextBlock Text="配置翻译引擎的 API 密钥以获得更稳定的翻译服务"
                       FontSize="13"
                       Foreground="{DynamicResource ClaudeTextSecondary}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="百度翻译"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="免费 200 万字符/月"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="App ID"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding BaiduAppId, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="百度翻译 App ID"
                                 AutomationProperties.HelpText="输入百度翻译的 App ID"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Secret Key"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding BaiduSecretKey, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="百度翻译 Secret Key"
                                 AutomationProperties.HelpText="输入百度翻译的 Secret Key"/>

                        <Button Content="清除百度密钥"
                                Style="{DynamicResource ClaudeButtonDanger}"
                                Command="{Binding ClearBaiduCredentialsCommand}"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="清除百度密钥"
                                AutomationProperties.HelpText="删除已保存的百度翻译 API 密钥"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="DeepL 翻译"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="翻译质量最佳 · 免费版 50 万字符/月"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="API Key"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding DeepLApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="DeepL API Key"
                                 AutomationProperties.HelpText="输入 DeepL 翻译的 API Key"/>

                        <Button Content="清除 DeepL 密钥"
                                Style="{DynamicResource ClaudeButtonDanger}"
                                Command="{Binding ClearDeepLKeyCommand}"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="清除 DeepL 密钥"
                                AutomationProperties.HelpText="删除已保存的 DeepL API Key"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="翻译语言"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="设置默认的源语言和目标语言，悬浮窗启动时会使用此配置"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="源语言（被翻译语言）"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SourceLanguage}"
                                  Margin="0,0,0,14"
                                  AutomationProperties.Name="源语言"
                                  AutomationProperties.HelpText="选择被翻译的语言，自动为自动检测"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="目标语言（翻译结果语言）"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding TargetLanguage}"
                                  Margin="0,0,0,8"
                                  AutomationProperties.Name="目标语言"
                                  AutomationProperties.HelpText="选择翻译结果的语言"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="快捷键配置"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="点击输入框后按下快捷键组合即可录制，修改后立即生效。点击 × 可清除快捷键"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="显示/隐藏悬浮窗"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ToggleWindowHotkeyBox"
                                    Grid.Column="0"
                                    Background="{DynamicResource ClaudeInputBg}"
                                    BorderBrush="{DynamicResource ClaudeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,10"
                                    Cursor="Hand"
                                    Focusable="True"
                                    MouseLeftButtonDown="HotkeyBox_MouseLeftButtonDown"
                                    GotFocus="HotkeyBorder_GotFocus"
                                    LostFocus="HotkeyBorder_LostFocus"
                                    Tag="ToggleWindow">
                                <TextBlock Text="{Binding ToggleWindowHotkeyDisplay, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{DynamicResource ClaudeText}"/>
                            </Border>
                            <Button Grid.Column="1" Content="×"
                                    Width="32" Height="32" Margin="8,0,0,0"
                                    FontSize="16" Padding="0"
                                    Style="{DynamicResource ClaudeButtonSecondary}"
                                    Click="ClearHotkeyButton_Click"
                                    Tag="ToggleWindow"
                                    ToolTip="清除快捷键"
                                    AutomationProperties.Name="清除显示隐藏悬浮窗快捷键"/>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="划词翻译"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="SelectionTranslateHotkeyBox"
                                    Grid.Column="0"
                                    Background="{DynamicResource ClaudeInputBg}"
                                    BorderBrush="{DynamicResource ClaudeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,10"
                                    Cursor="Hand"
                                    Focusable="True"
                                    MouseLeftButtonDown="HotkeyBox_MouseLeftButtonDown"
                                    GotFocus="HotkeyBorder_GotFocus"
                                    LostFocus="HotkeyBorder_LostFocus"
                                    Tag="SelectionTranslate">
                                <TextBlock Text="{Binding SelectionTranslateHotkeyDisplay, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{DynamicResource ClaudeText}"/>
                            </Border>
                            <Button Grid.Column="1" Content="×"
                                    Width="32" Height="32" Margin="8,0,0,0"
                                    FontSize="16" Padding="0"
                                    Style="{DynamicResource ClaudeButtonSecondary}"
                                    Click="ClearHotkeyButton_Click"
                                    Tag="SelectionTranslate"
                                    ToolTip="清除快捷键"
                                    AutomationProperties.Name="清除划词翻译快捷键"/>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="框选翻译"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RegionTranslateHotkeyBox"
                                    Grid.Column="0"
                                    Background="{DynamicResource ClaudeInputBg}"
                                    BorderBrush="{DynamicResource ClaudeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,10"
                                    Cursor="Hand"
                                    Focusable="True"
                                    MouseLeftButtonDown="HotkeyBox_MouseLeftButtonDown"
                                    GotFocus="HotkeyBorder_GotFocus"
                                    LostFocus="HotkeyBorder_LostFocus"
                                    Tag="RegionTranslate">
                                <TextBlock Text="{Binding RegionTranslateHotkeyDisplay, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{DynamicResource ClaudeText}"/>
                            </Border>
                            <Button Grid.Column="1" Content="×"
                                    Width="32" Height="32" Margin="8,0,0,0"
                                    FontSize="16" Padding="0"
                                    Style="{DynamicResource ClaudeButtonSecondary}"
                                    Click="ClearHotkeyButton_Click"
                                    Tag="RegionTranslate"
                                    ToolTip="清除快捷键"
                                    AutomationProperties.Name="清除框选翻译快捷键"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="AI 翻译"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="配置 LLM 供应商，本地 Gemma 4 E4B 为默认源"/>
                        <local:LlmProviderSettingsPage/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="隐私与数据"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="查看、导出或删除本应用在本地保存的所有数据"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="📊 查看数据摘要"
                                    Style="{DynamicResource ClaudeButtonSecondary}"
                                    Command="{Binding ShowDataSummaryCommand}"
                                    Margin="0,0,8,0"
                                    AutomationProperties.Name="查看数据摘要"
                                    AutomationProperties.HelpText="显示本地存储的所有数据及其大小"/>
                            <Button Content="📤 导出我的数据"
                                    Style="{DynamicResource ClaudeButtonSecondary}"
                                    Command="{Binding ExportUserDataCommand}"
                                    AutomationProperties.Name="导出我的数据"
                                    AutomationProperties.HelpText="将所有本地数据导出为 ZIP 压缩包或 JSON 文件"/>
                        </StackPanel>

                        <Button Content="🗑️ 删除所有本地数据"
                                Style="{DynamicResource ClaudeButtonDanger}"
                                Command="{Binding DeleteUserDataCommand}"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="删除所有本地数据"
                                AutomationProperties.HelpText="清除所有设置、历史和缓存（不可撤销）"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="v1.1 新功能"/>
                        <TextBlock Style="{StaticResource SectionDesc}" Text="控制 v1.1 版本新增功能的行为"/>

                        <CheckBox IsChecked="{Binding ShowToastOnTranslate}" Margin="0,0,0,10"
                                  AutomationProperties.Name="复制翻译时显示右下角气泡提示"
                                  AutomationProperties.HelpText="开启后，复制翻译结果时会在屏幕右下角显示气泡提示">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="复制翻译时显示右下角气泡提示" Margin="0"/>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding EnableSelectionTranslate}" Margin="0,0,0,10"
                                  AutomationProperties.Name="启用 Ctrl+Shift+X 划词翻译"
                                  AutomationProperties.HelpText="开启后，选中文字并按 Ctrl+Shift+X 即可翻译所选内容">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="启用 Ctrl+Shift+X 划词翻译" Margin="0"/>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding EnableDockHide}"
                                  AutomationProperties.Name="悬浮窗拖到屏幕边缘自动贴边隐藏"
                                  AutomationProperties.HelpText="开启后，将悬浮窗拖到屏幕边缘会自动贴边隐藏">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="悬浮窗拖到屏幕边缘自动贴边隐藏" Margin="0"/>
                        </CheckBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource ClaudeBg}" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ClaudeSuccess}"
                           FontSize="13" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{DynamicResource ClaudeButtonSecondary}"
                            Command="{Binding CancelCommand}" Margin="0,0,10,0"
                            AutomationProperties.Name="取消"
                            AutomationProperties.HelpText="放弃修改并关闭设置窗口"/>
                    <Button Content="保存设置" Style="{DynamicResource ClaudeButtonPrimary}"
                            Command="{Binding SaveCommand}"
                            AutomationProperties.Name="保存设置"
                            AutomationProperties.HelpText="保存 API 和快捷键配置"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
