<Window x:Class="TranslateTool.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译历史"
        MinWidth="500"
        MinHeight="350"
        Width="700"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource ClaudeBg}">

    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ClaudeSurface}"
                BorderBrush="{DynamicResource ClaudeBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="翻译历史"
                           Foreground="{DynamicResource ClaudeText}"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Background="{DynamicResource ClaudeBg}"
                        BorderBrush="{DynamicResource ClaudeBorder}"
                        BorderThickness="1" CornerRadius="6"
                        Margin="12,0,8,0" Padding="8,4">
                    <TextBox x:Name="SearchBox"
                             Background="Transparent" BorderThickness="0"
                             FontSize="12" Foreground="{DynamicResource ClaudeText}"/>
                </Border>

                <TextBlock x:Name="StatusText" Grid.Column="2"
                           Foreground="{DynamicResource ClaudeTextMuted}"
                           FontSize="12" VerticalAlignment="Center"/>

                <Button Grid.Column="3" Content="清空历史"
                        Style="{DynamicResource ClaudeButtonDanger}"
                        Command="{Binding ClearHistoryCommand}" Padding="12,6"/>
            </Grid>
        </Border>

        <ListBox x:Name="HistoryList"
                 ItemsSource="{Binding History}"
                 FontSize="12"
                 SelectionChanged="HistoryList_SelectionChanged"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource ClaudeSurface}"
                            BorderBrush="{DynamicResource ClaudeBorderLight}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,10" Margin="0,3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                               Foreground="{DynamicResource ClaudeTextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding Engine}"
                                               Foreground="{DynamicResource ClaudePrimary}" FontSize="11"
                                               Margin="10,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="复制原文"
                                            Tag="{Binding SourceText}" Click="CopySource_Click"
                                            Style="{DynamicResource ClaudeButtonSecondary}"
                                            Padding="8,3" FontSize="10" Margin="0,0,4,0"/>
                                    <Button Content="复制译文"
                                            Tag="{Binding TranslatedText}" Click="CopyTranslated_Click"
                                            Style="{DynamicResource ClaudeButtonPrimary}"
                                            Padding="8,3" FontSize="10"/>
                                </StackPanel>
                            </Grid>

                            <TextBox Grid.Row="1" Text="{Binding SourceText}"
                                     TextWrapping="Wrap"
                                     Foreground="{DynamicResource ClaudeTextSecondary}"
                                     Margin="0,6,0,0" FontWeight="SemiBold" FontSize="12"
                                     Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" Cursor="IBeam"/>

                            <TextBox Grid.Row="2" Text="{Binding TranslatedText}"
                                     TextWrapping="Wrap"
                                     Foreground="{DynamicResource ClaudeText}"
                                     Margin="0,4,0,0" FontSize="12"
                                     Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" Cursor="IBeam"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
