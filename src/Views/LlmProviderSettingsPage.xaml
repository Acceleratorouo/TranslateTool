<UserControl x:Class="TranslateTool.Views.LlmProviderSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ClaudeBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource ClaudeSurface}" BorderBrush="{DynamicResource ClaudeBorder}"
                        BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="供应商" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource ClaudeText}" Margin="0,0,0,12"/>

                        <ItemsControl ItemsSource="{Binding Providers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" Foreground="{DynamicResource ClaudeText}"/>
                                                <TextBlock Text="（默认）" Foreground="{DynamicResource ClaudeSuccess}" Margin="6,0,0,0"
                                                           Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding BaseUrl}" FontSize="11" Foreground="{DynamicResource ClaudeTextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="编辑" Command="{Binding DataContext.EditProviderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{DynamicResource ClaudeButtonSecondary}" Margin="0,0,4,0"/>
                                            <Button Content="默认" Command="{Binding DataContext.SetDefaultProviderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{DynamicResource ClaudeButtonSecondary}" Margin="0,0,4,0"/>
                                            <Button Content="删除" Command="{Binding DataContext.DeleteProviderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{DynamicResource ClaudeButtonDanger}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="从模板添加" Command="{Binding AddFromTemplateCommand}"
                                    Style="{DynamicResource ClaudeButtonSecondary}" Margin="0,0,8,0"/>
                            <Button Content="自定义添加" Command="{Binding AddCustomCommand}"
                                    Style="{DynamicResource ClaudeButtonSecondary}" Margin="0,0,8,0"/>
                            <Button Content="部署本地 Gemma 4 E4B" Command="{Binding DeployLocalGemmaCommand}"
                                    Style="{DynamicResource ClaudeButtonPrimary}" Margin="0,0,8,0"/>
                        </StackPanel>

                        <!-- 部署进度条 -->
                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding HasDeployStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding DeployStatusText}" Foreground="{DynamicResource ClaudeTextSecondary}"
                                       Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding DeployProgress}" Maximum="100" Height="6"
                                         Visibility="{Binding IsDeploying, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- 本地部署操作文档 -->
                        <Expander Header="📖 本地部署操作文档" Margin="0,12,0,0"
                                  Foreground="{DynamicResource ClaudeText}"
                                  Background="{DynamicResource ClaudeInputBg}" BorderBrush="{DynamicResource ClaudeBorder}">
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="本地部署 Gemma 4 E4B 完整流程：" FontWeight="Medium"
                                           Foreground="{DynamicResource ClaudeText}" Margin="0,0,0,8"/>
                                <TextBlock Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4">
                                    <Run Text="1. 安装 Ollama：前往"/>
                                    <Hyperlink NavigateUri="https://ollama.com" RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="{DynamicResource ClaudePrimary}">ollama.com</Hyperlink>
                                    <Run Text=" 下载并安装（Windows 版安装包，约 300MB）。"/>
                                </TextBlock>
                                <TextBlock Text="2. 安装完成后，确认 Ollama 服务已启动（系统托盘会出现 Ollama 图标，或终端运行 ollama --version 验证）。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="3. 点击上方「部署本地 Gemma 4 E4B」按钮，等待下载完成（进度条显示实时进度，模型约 5GB，请保持网络畅通）。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="4. 部署完成后，在上方供应商列表中确认 Ollama 供应商已存在。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="5. 点击 Ollama 供应商的「编辑」按钮，确认 BaseUrl 为 http://localhost:11434/v1，模型列表填入 gemma4:e4b。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="6. 点击 Ollama 供应商的「默认」按钮，将其设为 AI 翻译默认源。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="7. 在主界面右键菜单 → 翻译引擎 → 选择「AI 翻译」。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="8. 开始翻译！选中文本即可自动使用本地 Gemma 4 E4B 进行 AI 翻译，无需联网，隐私安全。"
                                           Foreground="{DynamicResource ClaudeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="提示：如果 Ollama 服务未自动启动，可在终端运行 ollama serve 手动启动。首次翻译可能稍慢（模型加载到内存），后续翻译会更快。"
                                           Foreground="{DynamicResource ClaudeTextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ClaudeSurface}" BorderBrush="{DynamicResource ClaudeBorder}"
                        BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="AI 翻译参数" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource ClaudeText}" Margin="0,0,0,12"/>

                        <TextBlock Text="系统提示词" Foreground="{DynamicResource ClaudeTextSecondary}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource ClaudeInputBg}" Foreground="{DynamicResource ClaudeText}"
                                 Padding="10,8" Margin="0,0,0,12" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>

                        <TextBlock Text="温度" Foreground="{DynamicResource ClaudeTextSecondary}" Margin="0,0,0,6"/>
                        <Slider Minimum="0" Maximum="1" TickFrequency="0.1" Value="{Binding Temperature}"
                                Margin="0,0,0,12"/>

                        <TextBlock Text="最大 Token" Foreground="{DynamicResource ClaudeTextSecondary}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource ClaudeInputBg}" Foreground="{DynamicResource ClaudeText}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="超时秒数" Foreground="{DynamicResource ClaudeTextSecondary}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource ClaudeInputBg}" Foreground="{DynamicResource ClaudeText}"
                                 Padding="10,8" Margin="0,0,0,12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource ClaudeSuccess}"/>
            <Button Content="保存" Command="{Binding SaveSettingsCommand}"
                    Style="{DynamicResource ClaudeButtonPrimary}"/>
        </StackPanel>
    </Grid>
</UserControl>
