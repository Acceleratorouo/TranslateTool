<Window x:Class="TranslateTool.Views.RegionSelectorOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="#40000000"
        Topmost="True"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowState="Maximized"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Canvas Background="Transparent"
            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
            MouseMove="Canvas_MouseMove"
            MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
        <!-- 选区矩形 -->
        <Rectangle x:Name="SelectionRect"
                   Fill="#202196F3"
                   Stroke="#2196F3"
                   StrokeThickness="2"
                   Visibility="Collapsed"/>
        
        <!-- 选区尺寸提示 -->
        <Border x:Name="SizeLabel"
                Background="#CC2196F3"
                CornerRadius="4"
                Padding="8,4"
                Visibility="Collapsed"
                Canvas.Left="0"
                Canvas.Top="0">
            <TextBlock x:Name="SizeText"
                       Foreground="White"
                       FontSize="12"/>
        </Border>
        
        <!-- 顶部提示 -->
        <Border Background="#99000000"
                Canvas.Left="0"
                Canvas.Top="0"
                Width="1920"
                Height="40"
                AutomationProperties.Name="框选翻译提示"
                AutomationProperties.HelpText="拖动鼠标选择要翻译的屏幕区域，按 ESC 取消">
            <TextBlock Text="🖱️ 拖动鼠标选择翻译区域 | ESC 取消"
                       Foreground="White"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       AutomationProperties.Name="拖动鼠标选择翻译区域，按 ESC 取消"/>
        </Border>
    </Canvas>
</Window>
