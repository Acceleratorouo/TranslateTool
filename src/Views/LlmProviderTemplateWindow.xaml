<Window x:Class="TranslateTool.Views.LlmProviderTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择供应商模板"
        Height="420" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ClaudeBg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="选择内置供应商模板"
                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ClaudeText}"
                   Margin="0,0,0,16"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding Templates}"
                 SelectedItem="{Binding SelectedTemplate}"
                 Background="{DynamicResource ClaudeSurface}"
                 BorderBrush="{DynamicResource ClaudeBorder}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource ClaudeText}"/>
                        <TextBlock Text="{Binding HomepageUrl}" FontSize="11" Foreground="{DynamicResource ClaudeTextMuted}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Command="{Binding CancelCommand}"
                    Style="{DynamicResource ClaudeButtonSecondary}" Margin="0,0,8,0"/>
            <Button Content="选择" Command="{Binding SelectCommand}"
                    Style="{DynamicResource ClaudeButtonPrimary}"/>
        </StackPanel>
    </Grid>
</Window>
