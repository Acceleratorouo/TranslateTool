<Window x:Class="TranslateTool.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:TranslateTool.ViewModels"
        Title="翻译工具"
        MinWidth="380"
        MinHeight="280"
        Width="440"
        Height="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ResizeMode="CanResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

    <Window.DataContext>
        <vm:FloatingWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LangTag" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ClaudePrimary}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ClaudePrimaryLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangTagText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ClaudeSurface}"
            BorderBrush="{DynamicResource ClaudeBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ClaudeSurface}"
                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="24" Height="24"
                                CornerRadius="6"
                                Background="{DynamicResource ClaudePrimary}"
                                Margin="0,0,10,0">
                            <TextBlock Text="T"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="翻译工具"
                                   Foreground="{DynamicResource ClaudeText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="📌"
                                Style="{DynamicResource ClaudeWindowButton}"
                                ToolTip="始终置顶"
                                Click="PinButton_Click"/>
                        <Button Content="─"
                                Style="{DynamicResource ClaudeWindowButton}"
                                Click="MinimizeButton_Click"/>
                        <Button Content="✕"
                                Style="{DynamicResource ClaudeWindowButton}"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 语言选择器 -->
            <Border Grid.Row="1"
                    Margin="16,12,16,8"
                    Background="{DynamicResource ClaudeBg}"
                    CornerRadius="10"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource LangTag}"
                            HorizontalAlignment="Stretch"
                            MouseLeftButtonDown="SourceLangBorder_MouseLeftButtonDown">
                        <TextBlock Text="{Binding SourceLanguage}"
                                   Style="{StaticResource LangTagText}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Button Grid.Column="1"
                            Content="⇄"
                            Style="{DynamicResource ClaudeWindowButton}"
                            Command="{Binding SwapLanguagesCommand}"
                            ToolTip="交换语言"
                            FontSize="16"
                            Width="32"
                            Height="32"/>

                    <Border Grid.Column="2"
                            Background="{DynamicResource ClaudePrimaryDark}"
                            CornerRadius="6"
                            Padding="14,7"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            MouseLeftButtonDown="TargetLangBorder_MouseLeftButtonDown">
                        <TextBlock Text="{Binding TargetLanguage}"
                                   Style="{StaticResource LangTagText}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 翻译结果区域 -->
            <Border Grid.Row="2"
                    Margin="16,4,16,8"
                    Background="{DynamicResource ClaudeSurface}"
                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding ResultText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ClaudeTextMuted}"
                                   FontSize="14"
                                   LineHeight="22"
                                   Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Margin="0,0,0,8">
                                <Run Text="{Binding EngineInfo, Mode=OneWay}"
                                     Foreground="{DynamicResource ClaudePrimary}"
                                     FontWeight="SemiBold"
                                     FontSize="11"/>
                            </TextBlock>

                            <!-- 原文 -->
                            <Border Background="{DynamicResource ClaudeBg}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,12"
                                    Cursor="Hand"
                                    ToolTip="点击复制原文"
                                    MouseLeftButtonDown="SourceText_MouseLeftButtonDown">
                                <StackPanel>
                                    <TextBlock Text="原文"
                                               Foreground="{DynamicResource ClaudeTextMuted}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SourceText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ClaudeTextSecondary}"
                                               FontSize="13"
                                               LineHeight="20"/>
                                </StackPanel>
                            </Border>

                            <!-- 译文 -->
                            <Border Background="{DynamicResource ClaudeSurface}"
                                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Cursor="Hand"
                                    ToolTip="点击复制译文"
                                    MouseLeftButtonDown="TranslatedText_MouseLeftButtonDown">
                                <StackPanel>
                                    <TextBlock Text="译文"
                                               Foreground="{DynamicResource ClaudeTextMuted}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TranslatedText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ClaudeText}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               LineHeight="22"/>
                                </StackPanel>
                            </Border>

                            <!-- 多引擎对比 -->
                            <Border Visibility="{Binding ShowComparison, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,16,0,0"
                                    Padding="12"
                                    Background="{DynamicResource ClaudeBg}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="多引擎对比"
                                               Foreground="{DynamicResource ClaudeText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding ComparisonResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10"
                                                        Background="{DynamicResource ClaudeSurface}"
                                                        CornerRadius="6"
                                                        BorderBrush="{DynamicResource ClaudeBorder}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding EngineName}"
                                                                   Foreground="{DynamicResource ClaudePrimary}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding TranslatedText}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource ClaudeText}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 底部操作栏 -->
            <Border Grid.Row="3"
                    Margin="16,4,16,16"
                    Padding="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Ctrl+Shift+T 唤出"
                               Foreground="{DynamicResource ClaudeTextMuted}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🔄 对比"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding CompareEnginesCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"/>
                        <Button Content="🔊 原文"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding SpeakSourceCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"/>
                        <Button Content="🔊 译文"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding SpeakTranslatedCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"/>
                        <Button Content="复制译文"
                                Style="{DynamicResource ClaudeButtonPrimary}"
                                Command="{Binding CopyResultCommand}"
                                Padding="16,7"
                                FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
