<Window x:Class="TranslateTool.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:TranslateTool.ViewModels"
        Title="翻译工具"
        MinWidth="380"
        MinHeight="280"
        Width="440"
        Height="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ResizeMode="CanResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        KeyDown="Window_KeyDown"
        Focusable="True"
        KeyboardNavigation.TabNavigation="Cycle">

    <Window.DataContext>
        <vm:FloatingWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LangTag" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ClaudePrimary}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ClaudePrimaryLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangTagText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ClaudeSurface}"
            BorderBrush="{DynamicResource ClaudeBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="6"
            AutomationProperties.Name="翻译工具悬浮窗"
            AutomationProperties.HelpText="显示翻译结果、语言选择和操作按钮">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ClaudeSurface}"
                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="24" Height="24"
                                CornerRadius="6"
                                Background="{DynamicResource ClaudePrimary}"
                                Margin="0,0,10,0">
                            <TextBlock Text="T"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="翻译工具"
                                   Foreground="{DynamicResource ClaudeText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="📌"
                                Style="{DynamicResource ClaudeWindowButton}"
                                ToolTip="始终置顶"
                                Click="PinButton_Click"
                                AutomationProperties.Name="置顶"
                                AutomationProperties.HelpText="将窗口保持在最前"/>
                        <Button Content="─"
                                Style="{DynamicResource ClaudeWindowButton}"
                                Click="MinimizeButton_Click"
                                AutomationProperties.Name="最小化"
                                AutomationProperties.HelpText="最小化窗口到任务栏"/>
                        <Button Content="✕"
                                Style="{DynamicResource ClaudeWindowButton}"
                                Click="CloseButton_Click"
                                AutomationProperties.Name="关闭"
                                AutomationProperties.HelpText="关闭窗口到托盘"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 语言选择器 -->
            <Border Grid.Row="1"
                    Margin="16,12,16,8"
                    Background="{DynamicResource ClaudeBg}"
                    CornerRadius="10"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource LangTag}"
                            HorizontalAlignment="Stretch"
                            MouseLeftButtonDown="SourceLangBorder_MouseLeftButtonDown"
                            KeyDown="SourceLangBorder_KeyDown"
                            Focusable="True"
                            AutomationProperties.Name="源语言"
                            AutomationProperties.HelpText="点击或回车更改源语言"
                            AutomationProperties.LabeledBy="{Binding ElementName=SourceLangText}">
                        <TextBlock x:Name="SourceLangText" Text="{Binding SourceLanguage}"
                                   Style="{StaticResource LangTagText}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Button Grid.Column="1"
                            Content="⇄"
                            Style="{DynamicResource ClaudeWindowButton}"
                            Command="{Binding SwapLanguagesCommand}"
                            ToolTip="交换语言"
                            FontSize="16"
                            Width="32"
                            Height="32"
                            AutomationProperties.Name="交换源语言和目标语言"/>

                    <Border Grid.Column="2"
                            Background="{DynamicResource ClaudePrimaryDark}"
                            CornerRadius="6"
                            Padding="14,7"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            MouseLeftButtonDown="TargetLangBorder_MouseLeftButtonDown"
                            KeyDown="TargetLangBorder_KeyDown"
                            Focusable="True"
                            AutomationProperties.Name="目标语言"
                            AutomationProperties.HelpText="点击或回车更改目标语言">
                        <TextBlock Text="{Binding TargetLanguage}"
                                   Style="{StaticResource LangTagText}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 翻译结果区域 -->
            <Border Grid.Row="2"
                    Margin="16,4,16,8"
                    Background="{DynamicResource ClaudeSurface}"
                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    AutomationProperties.Name="翻译结果"
                    AutomationProperties.HelpText="显示当前翻译结果">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding ResultText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ClaudeTextMuted}"
                                   FontSize="14"
                                   LineHeight="22"
                                   Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVisibility}}"
                                   AutomationProperties.Name="翻译提示"
                                   AutomationProperties.LiveSetting="Polite"/>

                        <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Margin="0,0,0,8">
                                <Run Text="{Binding EngineInfo, Mode=OneWay}"
                                     Foreground="{DynamicResource ClaudePrimary}"
                                     FontWeight="SemiBold"
                                     FontSize="11"/>
                            </TextBlock>

                            <!-- 原文 -->
                            <Border Background="{DynamicResource ClaudeBg}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,12"
                                    Cursor="Hand"
                                    ToolTip="点击复制原文"
                                    MouseLeftButtonDown="SourceText_MouseLeftButtonDown"
                                    KeyDown="SourceTextBorder_KeyDown"
                                    Focusable="True"
                                    AutomationProperties.Name="原文"
                                    AutomationProperties.HelpText="点击或回车复制原文">
                                <StackPanel>
                                    <TextBlock Text="原文"
                                               Foreground="{DynamicResource ClaudeTextMuted}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SourceText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ClaudeTextSecondary}"
                                               FontSize="13"
                                               LineHeight="20"
                                               FlowDirection="{Binding SourceText, Converter={StaticResource TextToFlowDirection}}"
                                               TextAlignment="{Binding SourceText, Converter={StaticResource TextToAlignment}}"
                                               AutomationProperties.Name="原文内容"
                                               AutomationProperties.LiveSetting="Polite"/>
                                </StackPanel>
                            </Border>

                            <!-- 译文 -->
                            <Border Background="{DynamicResource ClaudeSurface}"
                                    BorderBrush="{DynamicResource ClaudeBorderLight}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Cursor="Hand"
                                    ToolTip="点击复制译文"
                                    MouseLeftButtonDown="TranslatedText_MouseLeftButtonDown"
                                    KeyDown="TranslatedTextBorder_KeyDown"
                                    Focusable="True"
                                    AutomationProperties.Name="译文"
                                    AutomationProperties.HelpText="点击或回车复制译文">
                                <StackPanel>
                                    <TextBlock Text="译文"
                                               Foreground="{DynamicResource ClaudeTextMuted}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TranslatedText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ClaudeText}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               LineHeight="22"
                                               FlowDirection="{Binding TranslatedText, Converter={StaticResource TextToFlowDirection}}"
                                               TextAlignment="{Binding TranslatedText, Converter={StaticResource TextToAlignment}}"
                                               AutomationProperties.Name="译文内容"
                                               AutomationProperties.LiveSetting="Polite"/>
                                </StackPanel>
                            </Border>

                            <!-- 多引擎对比 -->
                            <Border Visibility="{Binding ShowComparison, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,16,0,0"
                                    Padding="12"
                                    Background="{DynamicResource ClaudeBg}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="多引擎对比"
                                               Foreground="{DynamicResource ClaudeText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding ComparisonResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10"
                                                        Background="{DynamicResource ClaudeSurface}"
                                                        CornerRadius="6"
                                                        BorderBrush="{DynamicResource ClaudeBorder}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 引擎名 + 推荐标签 -->
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding EngineName}"
                                                                       Foreground="{DynamicResource ClaudePrimary}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       AutomationProperties.Name="引擎名称"/>
                                                            <!-- 推荐标签 -->
                                                            <Border Background="Gold"
                                                                    CornerRadius="4"
                                                                    Padding="4,2"
                                                                    Margin="6,0,0,0"
                                                                    Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="推荐"
                                                                           FontSize="10"
                                                                           Foreground="Black"
                                                                           FontWeight="Bold"
                                                                           AutomationProperties.Name="推荐"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- 译文 -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding TranslatedText}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource ClaudeText}"
                                                                   FontSize="12"
                                                                   Margin="8,0"
                                                                   FlowDirection="{Binding TranslatedText, Converter={StaticResource TextToFlowDirection}}"
                                                                   TextAlignment="{Binding TranslatedText, Converter={StaticResource TextToAlignment}}"
                                                                   AutomationProperties.Name="引擎译文"
                                                                   AutomationProperties.LiveSetting="Polite"/>

                                                        <!-- 评分显示 + 反馈按钮 -->
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Top"
                                                                    Margin="4,0,0,0">
                                                            <TextBlock Text="{Binding Score, StringFormat={}{0:F0}}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource ClaudeTextMuted}"
                                                                       FontWeight="Medium"/>
                                                            <TextBlock Text="分"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource ClaudeTextMuted}"
                                                                       Margin="2,0,0,0"/>
                                                            <Button Content="👍"
                                                                    Style="{DynamicResource ClaudeWindowButton}"
                                                                    Command="{Binding DataContext.VoteResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding EngineName, StringFormat='{}{0}|1'}"
                                                                    ToolTip="赞"
                                                                    FontSize="12"
                                                                    Margin="8,0,0,0"
                                                                    Padding="4,0"
                                                                    AutomationProperties.Name="赞"/>
                                                            <Button Content="👎"
                                                                    Style="{DynamicResource ClaudeWindowButton}"
                                                                    Command="{Binding DataContext.VoteResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding EngineName, StringFormat='{}{0}|-1'}"
                                                                    ToolTip="踩"
                                                                    FontSize="12"
                                                                    Margin="4,0,0,0"
                                                                    Padding="4,0"
                                                                    AutomationProperties.Name="踩"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 底部操作栏 -->
            <Border Grid.Row="3"
                    Margin="16,4,16,16"
                    Padding="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🔄 对比"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding CompareEnginesCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"
                                AutomationProperties.Name="多引擎对比"
                                AutomationProperties.HelpText="同时调用多个引擎并显示对比结果"/>
                        <Button Content="🔊 原文"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding SpeakSourceCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"
                                AutomationProperties.Name="朗读原文"
                                AutomationProperties.HelpText="用语音朗读原文"/>
                        <Button Content="🔊 译文"
                                Style="{DynamicResource ClaudeButtonSecondary}"
                                Command="{Binding SpeakTranslatedCommand}"
                                Padding="10,7"
                                FontSize="11"
                                Margin="0,0,6,0"
                                AutomationProperties.Name="朗读译文"
                                AutomationProperties.HelpText="用语音朗读译文"/>
                        <Button Content="复制译文"
                                Style="{DynamicResource ClaudeButtonPrimary}"
                                Command="{Binding CopyResultCommand}"
                                Padding="16,7"
                                FontSize="12"
                                AutomationProperties.Name="复制译文"
                                AutomationProperties.HelpText="将当前译文复制到剪贴板"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ResizeGrip x:Name="WindowResizeGrip"
                        Grid.RowSpan="4"
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,8,8"
                        Cursor="SizeNWSE"
                        MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                        AutomationProperties.Name="调整窗口大小"/>
        </Grid>
    </Border>
</Window>
