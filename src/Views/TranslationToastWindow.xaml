<Window x:Class="TranslateTool.Views.TranslationToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation Toast"
        Width="380"
        MinHeight="60"
        MaxHeight="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Cursor="Hand"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Focusable="True">

    <Window.Resources>
        <!-- 淡出动画 -->
        <Storyboard x:Key="FadeOutStoryboard"
                    Completed="FadeOutStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0"
                             Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource ClaudeSurface}"
            BorderBrush="{DynamicResource ClaudeBorderLight}"
            BorderThickness="1"
            CornerRadius="12"
            Effect="{DynamicResource ShadowMd}">
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 引擎标签 -->
            <Border x:Name="EngineTag"
                    Grid.Row="0"
                    Background="{DynamicResource ClaudePrimary}"
                    CornerRadius="4"
                    Padding="6,3"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8">
                <TextBlock x:Name="EngineText"
                           Text="DeepL"
                           Foreground="{DynamicResource ClaudeTextInverse}"
                           FontSize="10"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- 原文 -->
            <TextBlock x:Name="SourceTextBlock"
                       Grid.Row="1"
                       Text="原文"
                       Foreground="{DynamicResource ClaudeTextMuted}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap"
                       MaxHeight="36"
                       LineStackingStrategy="BlockLineHeight"
                       Margin="0,0,0,8"/>

            <!-- 译文 -->
            <TextBlock x:Name="TranslatedTextBlock"
                       Grid.Row="1"
                       Text="译文"
                       Foreground="{DynamicResource ClaudeText}"
                       FontSize="15"
                       FontWeight="Medium"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap"
                       MaxHeight="66"
                       LineStackingStrategy="BlockLineHeight"
                       Margin="0,18,0,0"/>
        </Grid>
    </Border>
</Window>
