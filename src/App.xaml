<Application x:Class="TranslateTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:TranslateTool"
             xmlns:utils="clr-namespace:TranslateTool.Utils"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
                <!-- 主题颜色字典 - 通过 ThemeService 动态切换 -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================ -->
            <!-- Converters -->
            <!-- ============================================ -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <utils:TextToFlowDirectionConverter x:Key="TextToFlowDirection"/>
            <utils:TextToAlignmentConverter x:Key="TextToAlignment"/>

            <!-- ============================================ -->
            <!-- 焦点视觉样式（无障碍键盘导航） -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeFocusVisual" TargetType="Control">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle Stroke="{DynamicResource ClaudePrimary}"
                                       StrokeThickness="2"
                                       StrokeDashArray="2 2"
                                       RadiusX="4" RadiusY="4"
                                       SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 圆角（不变） -->
            <!-- ============================================ -->
            <CornerRadius x:Key="RadiusSm">6</CornerRadius>
            <CornerRadius x:Key="RadiusMd">10</CornerRadius>
            <CornerRadius x:Key="RadiusLg">14</CornerRadius>
            <CornerRadius x:Key="RadiusXl">20</CornerRadius>

            <!-- ============================================ -->
            <!-- 主按钮 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeButtonPrimary" TargetType="Button">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="18,9"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ClaudeFocusVisual}"/>
                <Setter Property="Background" Value="{DynamicResource ClaudePrimary}"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeTextInverse}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudePrimaryLight}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudePrimaryDark}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeDisabled}"/>
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 次要按钮 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeButtonSecondary" TargetType="Button">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Padding" Value="18,9"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ClaudeFocusVisual}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeText}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ClaudeBorder}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeButtonHover}"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ClaudePrimary}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeButtonPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 危险按钮 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeButtonDanger" TargetType="Button">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ClaudeFocusVisual}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeError}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ClaudeError}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeErrorBg}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeErrorBorder}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 窗口控制按钮 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeWindowButton" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeTextSecondary}"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ClaudeFocusVisual}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource RadiusSm}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeButtonHover}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ClaudeText}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ClaudeButtonPressed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 输入框样式 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeTextBox" TargetType="TextBox">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Background" Value="{DynamicResource ClaudeInputBg}"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource ClaudeFocusVisual}"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeText}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ClaudeBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="{DynamicResource ClaudePrimary}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ClaudeBorderFocus}"/>
                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ClaudePrimaryMuted}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- 滚动条样式 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeScrollBar" TargetType="ScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background" Value="{DynamicResource ClaudeScrollTrack}"/>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ============================================ -->
            <!-- 工具提示样式 -->
            <!-- ============================================ -->
            <Style x:Key="ClaudeToolTip" TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource ClaudeTooltipBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource ClaudeTooltipText}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- ============================================ -->
            <!-- 旧样式兼容 -->
            <!-- ============================================ -->
            <Style x:Key="ButtonPrimary" TargetType="Button" BasedOn="{StaticResource ClaudeButtonPrimary}"/>
            <Style x:Key="ButtonSecondary" TargetType="Button" BasedOn="{StaticResource ClaudeButtonSecondary}"/>
            <Style x:Key="ButtonDanger" TargetType="Button" BasedOn="{StaticResource ClaudeButtonDanger}"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
